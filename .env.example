# Mega Sena Pro / Motor Elite X
# No required environment variables are needed for local execution.
#
# Optional runtime settings:
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# The app uses the bundled local CSV by default:
# dados/mega_sena_historico.csv
#
# CAIXA URLs are defined in src/carregar_dados.py and only used when the
# "Atualizar base oficial" action is triggered in the UI.
